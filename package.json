{
  "name": "@ledgerhq/zcash-utils",
  "version": "1.0.0",
  "description": "Native Zcash key derivation and shielded sync — Node.js (NAPI)",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LedgerHQ/ledger-zcash-utils.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "// ── NAPI (Node.js / Electron) ──────────────────────────────────────": "",
    "build": "./scripts/build-napi.sh",
    "build:debug": "DEBUG=1 ./scripts/build-napi.sh",
    "// ── CLI artifacts ───────────────────────────────────────────────────": "",
    "build:cli:macos": "./scripts/build-cli-macos.sh",
    "build:cli:linux": "./scripts/build-cli-linux.sh",
    "// ── Rust checks & tests ────────────────────────────────────────────": "",
    "check": "cargo check --workspace",
    "test": "cargo test --package zcash-crypto",
    "test:cli": "cargo test --package zcash-cli",
    "test:all": "cargo test --workspace",
    "// ── Coverage ───────────────────────────────────────────────────────": "",
    "coverage": "./scripts/coverage.sh",
    "coverage:open": "OPEN_REPORT=1 ./scripts/coverage.sh",
    "// ── Rustdoc ────────────────────────────────────────────────────────": "",
    "doc": "cargo doc --workspace --no-deps",
    "doc:open": "cargo doc --workspace --no-deps --open",
    "// ── CLI (ledger-zcash-cli) — usage: pnpm cli -- derive --mnemonic '...'": "",
    "cli": "cargo run -q -p zcash-cli",
    "cli:derive": "cargo run -q -p zcash-cli -- derive --help",
    "cli:tip": "cargo run -q -p zcash-cli -- tip --help",
    "cli:sync": "cargo run -q -p zcash-cli -- sync --help",
    "// ── Node.js validation & benchmarks ───────────────────────────────": "",
    "sync-tx": "tsx examples/sync-tx.node.ts --start-height 1130000 --end-height 1180000",
    "bench": "tsx examples/bench.ts --start-height 280000 --end-height 285000"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@napi-rs/cli": "^2.18.0",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.24.0",
  "license": "MIT"
}
